{
  "name": "exam-tracker-backend",
  "version": "1.0.0",
  "description": "Backend server for Exam Tracker app",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "worker": "python workers/telegram/worker.py",
    "dev:local": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local.ps1",
    "migrate:exam-session": "node scripts/backfill-exam-session.js",
    "normalize:status": "node scripts/normalize-status-column.js"
  },
  "dependencies": {
    "@replit/connectors-sdk": "^0.4.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "form-data": "^4.0.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2"
  }
}
